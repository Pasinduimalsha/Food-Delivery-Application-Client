version: '3.4'

services:
  food_delivery_app_client:
    container_name: food-delivery-application-client
    image: "{{ image_name }}"
    environment:
      NODE_ENV: prod
    ports:
      - "3000:80"
    restart: always
    networks:
      - food_delivery_network

networks:
  food_delivery_network:
    driver: bridge
